{
  "name": "mooncake-impact-factor-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:static-data": "moon build src/cli --target js && moon build src/static_search --target js && python3 scripts/build_index.py --db data/mooncake.db && python3 scripts/export_static_json.py --db data/mooncake.db --out public/data",
    "build:static": "node scripts/build_static_site.mjs",
    "serve:static": "python3 -m http.server 4173 -d out",
    "start": "next start",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "node --experimental-specifier-resolution=node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.13.0",
    "lucide-react": "^0.542.0",
    "next": "^16.2.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.9.2"
  }
}
